---
import Base from '../../layouts/Base.astro';

// The thread example: one record per hop, rendered top to bottom.
const THREAD = [
  { kind: 'Test Case', id: 'AUR-TC-001', desc: 'wizard → account active, zero tickets', link: 'tests →' },
  { kind: 'Acceptance Criterion', id: 'AUR-AC-001', desc: 'new customer set up, no support ticket', link: 'verifies →' },
  { kind: 'Product Requirement', id: 'AUR-PR-014', desc: 'self-serve onboarding flow', link: 'traces to →' },
  { kind: 'Business Requirement', id: 'AUR-BR-001', desc: 'onboarding under 2 days', link: 'which serves →' },
  { kind: 'Charter', id: 'AUR-charter', desc: 'objective: 14 days → under 2', link: null },
];

const anchors: [string, string][] = [
  ['unit', 'The unit of value'],
  ['thread-ex', 'The thread example'],
  ['schema', 'Schema requirement'],
];
---

<Base
  title="Traceability"
  description="Value lives in the links between thin, richly connected artifacts. Every requirement carries a stable ID and typed references, so lineage is a queryable graph CI checks."
  path="/principles/traceability/"
  anchors={anchors}
>
  <div style="display:flex;align-items:center;gap:8px;margin-bottom:13px;">
    <span class="layer-badge" style="background:var(--l1);">1</span>
    <span class="mono" style="font-size:11.5px;letter-spacing:.06em;text-transform:uppercase;color:var(--muted);">Layer 1 · Principles · Explainer 02</span>
  </div>
  <h1 class="h1" style="font-size:clamp(28px,4vw,42px);">Traceability over dense documentation.</h1>
  <p class="lead">Value lives in the links between thin, richly connected artifacts.</p>

  <div id="unit" style="margin:32px 0 48px;">
    <h2 class="h2-sm">The unit of value is the link.</h2>
    <p style="font-size:16px;color:var(--ink-2);max-width:60ch;margin:0 0 18px;">Dense documentation defeats its own purpose. A 40-page Word document describes a project in exhaustive detail, yet it cannot tell you <em style="font-style:italic;color:var(--ink);">why</em> a status is red or which decision accepted the risk that caused it, so you read everything to find anything.</p>
    <p style="font-size:16px;color:var(--ink-2);max-width:60ch;margin:0 0 18px;">Traceability replaces density with linkage. Each thin artifact (a charter, a RAID entry, a decision record) carries a stable ID and typed references to the others, so a reader can walk from any status to its root cause in five hops without opening a deck.</p>
  </div>

  <div id="thread-ex" style="margin-bottom:48px;">
    <h2 class="h2-sm">The thread in practice.</h2>
    <p style="font-size:16px;color:var(--ink-2);max-width:60ch;margin:0 0 22px;">Does every requirement get tested? Every hop below is a typed link that CI checks on every pull request.</p>
    <div style="position:relative;padding-left:28px;border-left:2px solid var(--accent-line);display:grid;gap:2px;">
      {THREAD.map((hop, i) => (
        <div style={`position:relative;padding:10px 0 ${hop.link ? '6px' : '0'};`}>
          <span style={`position:absolute;left:-36px;top:14px;width:${i === 0 || i === THREAD.length - 1 ? '13' : '11'}px;height:${i === 0 || i === THREAD.length - 1 ? '13' : '11'}px;border-radius:50%;background:${i === 0 || i === THREAD.length - 1 ? 'var(--accent)' : 'var(--bg)'};border:${i === 0 || i === THREAD.length - 1 ? '0' : '2px solid var(--accent)'};box-shadow:${i === 0 || i === THREAD.length - 1 ? '0 0 0 3px var(--bg),0 0 0 5px var(--accent-soft)' : 'none'};`}></span>
          <div style="background:var(--panel);border:1px solid var(--border);border-radius:10px;padding:12px 15px;">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;"><span class="kind-badge">{hop.kind}</span><span class="mono" style="font-size:11px;color:var(--muted);">{hop.id}</span></div>
            <div style="font-size:14px;color:var(--ink-2);">{hop.desc}</div>
          </div>
          {hop.link && <div class="mono" style="font-size:11px;color:var(--muted);margin:6px 0 0 2px;">{hop.link}</div>}
        </div>
      ))}
    </div>
  </div>

  <div id="schema" style="margin-bottom:48px;">
    <h2 class="h2-sm">The schema enforces this.</h2>
    <p style="font-size:16px;color:var(--ink-2);max-width:60ch;margin:0 0 18px;">Every requirement is an item with a stable ID and typed links, so the lineage is a queryable graph that CI checks. Ask "which requirements have no test?" and the tool answers.</p>
    <div class="code-block">
      <div class="code-titlebar">
        <span class="traffic-light" style="background:#ff5f57;"></span>
        <span class="traffic-light" style="background:#febc2e;"></span>
        <span class="traffic-light" style="background:#28c840;"></span>
        <span class="code-filename">documents/PRJ-001-AUR/prd.md</span>
      </div>
      <pre class="code-pre"><span class="cv">## Product Requirements</span>
- <span class="ck">**AUR-PR-014**</span> (<span class="cv">traces</span>: AUR-BR-001): the product shall
  provide a self-serve onboarding flow.

<span class="cv">## Acceptance Criteria</span>
- <span class="ck">**AUR-AC-001**</span> (<span class="cv">verifies</span>: AUR-PR-014): a new customer
  completes setup with no support ticket created.</pre>
    </div>
  </div>
</Base>
