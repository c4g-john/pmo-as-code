---
// The one shell every page renders through: header, sidebar, on-this-page
// rail, prev/next, provenance footer. Content arrives via <slot/>.
// Client JS is a single progressive-enhancement script (theme, menu, copy,
// search); every page is fully readable without it.
import '../styles/global.css';
import { NAV, pageFor, prevNext } from '../data/nav';
import { lastModified } from '../lib/dates';

interface Props {
  title: string;
  description: string;
  path: string;                      // '/why/' — canonical route
  anchors?: [string, string][];      // [id, label] for the on-this-page rail
  ogImage?: string;
  jsonLd?: object[];                 // page-specific blocks (task: delivery checklist)
  srcPath?: string;                  // override for pages outside the nav record (news entries)
}

const { title, description, path, anchors = [], ogImage = '/og.png', jsonLd = [] } = Astro.props;
const page = pageFor(path);
const { prev, next } = prevNext(path);
const canonical = new URL(path, Astro.site).href;
const fullTitle = path === '/' ? 'PMO as Code' : `${title} · PMO as Code`;
const srcPath = Astro.props.srcPath ?? page?.srcPath ?? 'src/pages/index.astro';
const srcUrl = `https://github.com/c4g-john/pmo-as-code/blob/main/${srcPath}`;
const updated = lastModified(srcPath);

const siteGraph = [
  {
    '@type': 'WebSite',
    name: 'PMO as Code',
    url: 'https://pmoascode.com/',
    description:
      'A vendor-neutral standard for running a PMO from version-controlled, testable documents. Project status is a build artifact.',
  },
  {
    '@type': 'SoftwareApplication',
    name: 'docassert',
    operatingSystem: 'macOS, Linux, Windows',
    applicationCategory: 'DeveloperApplication',
    description:
      'Unit testing for business documents — the PMO as Code reference implementation.',
    url: 'https://docassert.com',
    downloadUrl: 'https://pypi.org/project/docassert/',
    license: 'https://www.apache.org/licenses/LICENSE-2.0',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  },
  {
    '@type': 'TechArticle',
    headline: fullTitle,
    description,
    url: canonical,
    dateModified: updated,
    author: { '@type': 'Person', name: 'John Tanner', sameAs: 'https://www.linkedin.com/in/tannerjs' },
    isPartOf: { '@type': 'WebSite', url: 'https://pmoascode.com/' },
  },
  ...jsonLd,
];
const ld = JSON.stringify({ '@context': 'https://schema.org', '@graph': siteGraph }).replaceAll('</', '<\\/');
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={new URL(ogImage, Astro.site).href} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />
<link rel="canonical" href={canonical} />
<link rel="alternate" type="application/rss+xml" title="PMO as Code news" href="/rss.xml" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<meta name="theme-color" content="#0d1117" />
<script type="application/ld+json" set:html={ld} />
<link rel="preload" href="/fonts/public-sans-400.woff2" as="font" type="font/woff2" crossorigin />
<link rel="preload" href="/fonts/space-grotesk-700.woff2" as="font" type="font/woff2" crossorigin />
<noscript><style>#search-box { display: none; }</style></noscript>
<script is:inline>
  // Pre-paint: restore theme; rescue legacy hash routes (#/why -> /why/).
  (function () {
    try {
      var t = localStorage.getItem('theme');
      if (t === 'light' || t === 'dark') document.documentElement.setAttribute('data-theme', t);
    } catch (e) {}
    var h = location.hash;
    if (h && h.indexOf('#/') === 0) {
      var target = h.slice(1).replace(/\/?$/, '/');
      location.replace(target === '//' ? '/' : target);
    }
  })();
</script>
</head>
<body>

<a class="skip-link" href="#content">Skip to content</a>

<header id="app-header">
  <button id="mobile-menu-btn" aria-label="Toggle navigation" title="Menu">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
  </button>
  <a class="logo" href="/">
    <span class="logo-icon"><span class="logo-dot"></span></span>
    <span class="logo-text">PMO<span class="logo-sep">·</span>as<span class="logo-sep">·</span>Code</span>
  </a>
  <span class="version-badge mono">v1</span>
  <div class="spacer"></div>
  <button class="search-box" id="search-box" aria-label="Search docs">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
    <span>Search docs</span>
    <span class="kbd">⌘K</span>
  </button>
  <button class="icon-btn" id="theme-btn" title="Toggle theme">
    <span class="theme-glyph" id="theme-glyph">☾</span>
  </button>
  <a class="icon-btn" href="https://github.com/c4g-john/pmo-as-code-pipeline" target="_blank" rel="noopener" title="The pipeline repo">
    <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M12 1A11 11 0 0 0 8.5 22.4c.5.1.7-.2.7-.5v-2c-3 .7-3.7-1.3-3.7-1.3-.5-1.3-1.2-1.6-1.2-1.6-1-.7.1-.7.1-.7 1.1.1 1.7 1.1 1.7 1.1 1 1.7 2.6 1.2 3.2.9.1-.7.4-1.2.7-1.5-2.4-.3-5-1.2-5-5.3 0-1.2.4-2.1 1.1-2.9-.1-.3-.5-1.4.1-2.9 0 0 .9-.3 3 1.1a10.4 10.4 0 0 1 5.5 0c2.1-1.4 3-1.1 3-1.1.6 1.5.2 2.6.1 2.9.7.8 1.1 1.7 1.1 2.9 0 4.1-2.6 5-5 5.3.4.3.8 1 .8 2.1v3.1c0 .3.2.6.7.5A11 11 0 0 0 12 1Z"/></svg>
  </a>
</header>

<div id="app-body">
  <aside id="sidebar">
    {NAV.map((group) => (
      <div class="nav-group">
        <div class="nav-group-header">
          {group.layer && <span class="layer-badge" style={`background:${group.color};`}>{group.layer}</span>}
          <span class="nav-group-title">{group.title}</span>
        </div>
        {group.pages.map((p) => (
          <a class={`nav-link${p.path === path ? ' active' : ''}`} href={p.path} aria-current={p.path === path ? 'page' : undefined}>
            <span class="nav-dot"></span>{p.title}
          </a>
        ))}
      </div>
    ))}
  </aside>
  <div id="main-wrap">
    <div id="main-inner">
      <main id="content">
        <article data-pagefind-body={path === '/404/' ? undefined : ''}>
          <slot />
          {(prev || next) && (
            <div class="page-nav">
              {prev && (
                <a class="page-nav-link prev" href={prev.path}>
                  <div class="page-nav-label">← previous</div>
                  <div class="page-nav-title">{prev.title}</div>
                </a>
              )}
              {next && (
                <a class="page-nav-link next" href={next.path}>
                  <div class="page-nav-label">next →</div>
                  <div class="page-nav-title">{next.title}</div>
                </a>
              )}
            </div>
          )}
          <footer class="provenance">
            <span style="display:inline-flex;align-items:center;gap:7px;">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>
              <a href={srcUrl} target="_blank" rel="noopener" style="color:var(--ink-2);text-decoration:none;">{srcPath}</a>
            </span>
            <span class="prov-sep">|</span>
            <span>Updated <time datetime={updated}>{updated}</time></span>
            <span class="prov-sep">|</span>
            <span>written and maintained by John Tanner · C4G Enterprises</span>
            <span class="prov-sep">|</span>
            <a href="/news/" style="color:var(--ink-2);text-decoration:none;">News</a>
            <span class="prov-sep">|</span>
            <a href="/press/" style="color:var(--ink-2);text-decoration:none;">Press &amp; share kit</a>
            <a class="prov-edit" href={srcUrl} target="_blank" rel="noopener">Edit on GitHub →</a>
          </footer>
        </article>
      </main>
      {anchors.length > 0 && (
        <nav id="on-this-page" aria-label="On this page">
          <div class="onpage-title">On this page</div>
          <div class="onpage-list">
            {anchors.map(([id, label]) => (
              <a class="onpage-link" href={`#${id}`}>{label}</a>
            ))}
          </div>
        </nav>
      )}
    </div>
  </div>
</div>

<dialog id="search-dialog" aria-label="Search">
  <div id="pagefind-mount"></div>
</dialog>

<script src="/site.js" is:inline defer></script>
</body>
</html>
